[Unit]
Description=Calc2Key Pi Relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/calc2key/pirelay.env
ExecStart=/opt/calc2key/bin/Calc2KeyPiRelay --bridge ${BRIDGE_HOST}:${BRIDGE_PORT}
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
